---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { categories } from "../data/categories";
import mainBg from "../assets/main_bg.webp";
import kuzeImg from "../assets/kuze.webp";
import mechImg from "../assets/mech.webp";
import venceImg from "../assets/vence.webp";

const title = "Ručně vyráběné kožené výrobky a dekorace";
const description =
	"BB Craft – česká ruční práce. Kožené peněženky, popruhy na foťák, pouzdra na brýle a přírodní věnce z mechu a květin.";

const categoryImages = {
	kuze: kuzeImg,
	mech: mechImg,
	vence: venceImg,
};
---

<BaseLayout {title} {description}>
	<!-- ÚVODNÍ BACKGROUND OBRÁZEK PRO HEADER -->
	<section
		class="relative h-[60vh] min-h-[320px] w-screen -mt-[130px] left-1/2 right-1/2 -ml-[50vw] -mr-[50vw]"
	>
		<Image
			src={mainBg}
			alt="Úvodní pozadí"
			widths={[640, 1280, 1920, 2560]}
			sizes="100vw"
			loading="eager"
			fetchpriority="high"
			class="absolute inset-0 w-full h-full object-cover object-top"
		/>

		<!-- CATEGORY‑STYLE PRUH – STRONGER -->
		<div class="kaz absolute left-0 right-0 pointer-events-none"></div>
	</section>
	<!-- ŠNEKOVSKÁ FILOZOFIE -->
	<section class="mt-32 mb-32 text-center max-w-3xl mx-auto">
		<h1
			class="blur-heading text-xl md:text-2xl font-bold uppercase text-[#333333] font-manrope"
		>
			ŠNEKOVSKÁ FILOZOFIE, TRPĚLIVOST, DETAIL A KLID
		</h1>
		<p
			class="mt-6 text-xs md:text-sm leading-relaxed tracking-wide text-[#444444] font-courier"
		>
			U nás jde všechno tempem, které dává věcem smysl. Kůže se nedá
			uspěchat, mech má vlastní nálady a přírodní materiály si říkají o
			prostor, aby vynikly. Děláme věci pomalu, poctivě a s takovou
			pozorností, že by to schválil i šnek. Výsledek? Výrobky, které mají
			charakter, voní přírodou a vydrží déle než první dojem. Vítejte.
		</p>
	</section>
	<!-- HERO – 3 velké obrázky s barevným overlayem -->
	<section class="mt-10">
		<div class="grid gap-6 md:grid-cols-3 blur-heading">
			{
				categories.map((category) => (
					<a
						href={`/produkty/${category.slug}`}
						class="group relative block aspect-[4/5] overflow-hidden"
					>
						<Image
							src={categoryImages[category.slug]}
							alt={category.label}
							widths={[480, 768, 1024]}
							sizes="(min-width: 768px) 33vw, 100vw"
							class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
						/>
						<div class="absolute inset-0 flex items-center justify-center text-black text-xl md:text-2xl uppercase font-semibold">
							{category.label.toUpperCase()}
						</div>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
