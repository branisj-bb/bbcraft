---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categories } from '../../data/categories';

export async function getStaticPaths() {
  const produkty = await getCollection('produkty');

  return categories.map((category) => ({
    params: { category: category.slug },
    props: {
      category,
      produkty: produkty.filter((p) => p.data.category === category.slug)
    }
  }));
}

const { category, produkty: produktyKategorie } = Astro.props;
---

<BaseLayout title={category.seoTitle} description={category.seoDescription}>
  <div class="max-w-[94rem] mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8 uppercase blur-heading">{category.label}</h1>

    {produktyKategorie.length === 0 ? (
      <p class="text-sm text-neutral-500">
        V této kategorii zatím nemáme žádné produkty.
      </p>
    ) : (
      <div class="grid gap-16 md:grid-cols-2">
        {produktyKategorie.map((p) => (
          <ProductCard product={p.data} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
